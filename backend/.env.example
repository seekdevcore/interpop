# Interpop — variáveis de ambiente
# Copie para `.env` (gitignored) e ajuste os valores. Nunca commite o `.env`.

# ── Segurança ────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True

# ── Hosts / CORS / CSRF ──────────────────────────────────────────────────────
# Dev local — listar todas as origens que servirão o frontend.
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173
# Produção (Hostinger): trocar pelos domínios reais
# ALLOWED_HOSTS=interpop.cc,www.interpop.cc
# CORS_ALLOWED_ORIGINS=https://interpop.cc,https://www.interpop.cc
# CSRF_TRUSTED_ORIGINS=https://interpop.cc,https://www.interpop.cc

# URL pública do site (usada em links de email, sitemap, OG, etc)
SITE_URL=http://localhost:5173
# SITE_URL=https://interpop.cc

# ── Banco de dados ───────────────────────────────────────────────────────────
# Dev: SQLite por default (settings/development.py). Sem precisar setar.
# Produção: PostgreSQL via dj-database-url
# DATABASE_URL=postgresql://interpop:senha@localhost:5432/interpop_db

# ── Media / Static ───────────────────────────────────────────────────────────
MEDIA_ROOT=media
# Em produção no VPS:
# MEDIA_ROOT=/var/www/interpop/media

# ── Email ────────────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=interpop.cc@gmail.com

# Dev-only: True usa SMTP real (Gmail acima); False imprime no terminal.
USE_REAL_EMAIL=False

# ── django-axes (brute-force protection) ─────────────────────────────────────
# Em production default = 5 tentativas / 30min. Em dev = 20.
# Override se quiser pra dev mais paciente:
# AXES_FAILURE_LIMIT=20

# ── OAuth (a configurar depois de cadastrar apps em Google/Facebook) ─────────
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# FACEBOOK_OAUTH_CLIENT_ID=
# FACEBOOK_OAUTH_CLIENT_SECRET=
